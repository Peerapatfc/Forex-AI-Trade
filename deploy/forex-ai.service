[Unit]
Description=Forex AI Trading Bot
After=network.target

[Service]
Type=simple
User=forex
WorkingDirectory=/opt/forex-ai
ExecStart=/opt/forex-ai/venv/bin/python main.py
Restart=on-failure
RestartSec=30
EnvironmentFile=/opt/forex-ai/.env
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
