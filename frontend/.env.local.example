# URL of the FastAPI backend (running alongside the trading bot)
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000

# On Vercel, set this to your deployed API server:
# NEXT_PUBLIC_API_URL=https://your-server.com

# Optional: match PAPER_BALANCE from the backend .env
# Used to show the starting balance on the equity chart before any trades
NEXT_PUBLIC_PAPER_BALANCE=10000
